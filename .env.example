DATABASE_URL="postgresql://app:app@localhost:5432/reservation_saas"
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Pins "today"/business-hours date math to one timezone regardless of where
# the Node process runs (Vercel defaults to UTC). All restaurants are
# currently assumed to be in this single timezone -- see reservation-dates.ts.
TZ="America/Toronto"
